@model QL_Ban_Hang.Models.Category
@{
    ViewData["Title"] = "Sửa Category";
}

<section class="page-shell form-shell">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Area Admin</p>
            <h1>Sửa category</h1>
        </div>
    </div>

    <form asp-action="Edit" method="post" class="admin-form">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

        <div class="form-group">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Description"></label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="admin-actions">
            <a class="btn btn-outline-secondary" asp-action="Index">Quay lại</a>
            <button type="submit" class="btn btn-danger">Cập nhật</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
