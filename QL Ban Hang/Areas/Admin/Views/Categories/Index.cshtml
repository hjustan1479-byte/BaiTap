@model IEnumerable<QL_Ban_Hang.Models.Category>
@{
    ViewData["Title"] = "Quản lý Category";
}

<section class="page-shell">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Area Admin</p>
            <h1>Quản lý category</h1>
        </div>
        <a class="btn btn-danger" asp-action="Create">Thêm category</a>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success custom-alert">@successMessage</div>
    }

    <div class="admin-table-wrap">
        <table class="table admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Tên chủ đề</th>
                    <th>Mô tả</th>
                    <th>Số product</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td>@item.Description</td>
                        <td>@item.Products.Count</td>
                        <td class="table-actions">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Sửa</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
