@model QL_Ban_Hang.Models.Product
@{
    ViewData["Title"] = "Xóa Product";
}

<section class="page-shell form-shell">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Area Admin</p>
            <h1>Xóa product</h1>
        </div>
    </div>

    <div class="danger-box">
        <p>Bạn có chắc muốn xóa product <strong>@Model.Name</strong> không?</p>
        <p>Category hiện tại: <strong>@Model.Category?.Name</strong></p>
        <p>Sau khi xác nhận, product sẽ bị xóa khỏi hệ thống.</p>
    </div>

    <form asp-action="Delete" method="post" class="admin-actions">
        <input type="hidden" asp-for="Id" />
        <a class="btn btn-outline-secondary" asp-action="Index">Hủy</a>
        <button type="submit" class="btn btn-danger">Xác nhận xóa</button>
    </form>
</section>
