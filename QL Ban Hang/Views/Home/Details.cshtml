@model QL_Ban_Hang.Models.Product
@{
    ViewData["Title"] = "Chi tiết product";
    var discountPercent = Model.OriginalPrice <= 0
        ? 0
        : Math.Round((Model.OriginalPrice - Model.Price) / Model.OriginalPrice * 100);
}

<section class="page-shell">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Chi tiết product</p>
            <h1>@Model.Name</h1>
        </div>
        <a class="add-link" asp-action="Index" asp-route-categoryId="@Model.CategoryId">Quay lại danh sách</a>
    </div>

    <div class="details-layout">
        <h2 class="details-title">THÔNG TIN CHI TIẾT PRODUCT</h2>

        <div class="details-panel">
            <div class="details-cover">
                <img src="@Model.ImageUrl" alt="@Model.Name" />
            </div>

            <div class="details-content">
                <h2>@Model.Name</h2>

                <div class="details-specs">
                    <div><strong>Category:</strong> @Model.Category?.Name</div>
                    <div><strong>Tác giả / Thương hiệu:</strong> @Model.Author</div>
                    <div><strong>Mã product:</strong> SP-@Model.Id.ToString("D4")</div>
                    <div><strong>Trạng thái:</strong> Còn hàng</div>
                </div>

                <div class="price-line">
                    <span class="price-current">@Model.Price.ToString("N0") đ</span>
                    <span class="price-original">@Model.OriginalPrice.ToString("N0") đ</span>
                    <span class="discount-badge">-@discountPercent%</span>
                </div>

                <div class="delivery-line">
                    <div class="delivery-item">
                        <small>Vận chuyển</small>
                        <strong>Giao hàng nhanh</strong>
                    </div>
                    <div class="delivery-item">
                        <small>Đổi trả</small>
                        <span>Hỗ trợ đổi trả trong 30 ngày</span>
                    </div>
                    <div class="delivery-item">
                        <small>Quyền truy cập</small>
                        <span>Ai cũng có thể xem chi tiết</span>
                    </div>
                </div>

                <div class="quantity-line">
                    <strong>Số lượng:</strong>
                    <div class="quantity-box">
                        <button type="button">-</button>
                        <span>1</span>
                        <button type="button">+</button>
                    </div>
                </div>

                <p class="details-description">@Model.Description</p>

                <div class="details-actions">
                    <a class="btn btn-outline-danger" asp-action="Index" asp-route-categoryId="@Model.CategoryId">Xem thêm theo category</a>
                    <a class="btn btn-danger" asp-area="" asp-controller="Account" asp-action="Login">Mua ngay</a>
                </div>
            </div>
        </div>
    </div>
</section>
